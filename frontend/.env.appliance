# ──────────────────────────────────────────────────────────────────────────────
# .env.appliance — build-time env vars for the Pi kiosk SPA build
#
# Usage:
#   cp .env.appliance .env.local    (in hosaka_field-terminal/frontend/)
#   npm run build
#
# These values are baked into the JS bundle at build time.
# Never put secrets here — OPENAI_API_KEY lives only in the Pi's systemd
# EnvironmentFile (/opt/hosaka-field-terminal/.env), not in the frontend.
# ──────────────────────────────────────────────────────────────────────────────

# Point all LLM calls at the local FastAPI server instead of Vercel.
# The server's /api/gemini endpoint accepts the same wire format as Vercel's.
VITE_HOSAKA_API_BASE=http://127.0.0.1:8421

# Point the WebSocket agent client at the local server.
VITE_HOSAKA_AGENT_URL=ws://127.0.0.1:8421/ws/agent

# Magic word for the agent — override with your HOSAKA_ACCESS_TOKEN value.
# Leave blank to allow open local access (no auth on the local network).
VITE_HOSAKA_MAGIC_WORD=

# Settings button visibility (1=show, 0=hide in kiosk mode)
VITE_SHOW_SETTINGS=0
