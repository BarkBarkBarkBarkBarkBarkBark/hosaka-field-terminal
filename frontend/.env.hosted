# ─────────────────────────────────────────────────────────────────────────────
# .env.hosted — build-time env vars for the hosted SPA (terminal.hosaka.xyz)
#
# Usage:
#   Vercel: set these in Settings → Environment Variables
#   Local:  cp .env.hosted .env.local
#
# The SPA source is the same codebase as the Pi appliance. These env vars
# configure hosted mode: agent gated behind the magic word, WebSocket pointed
# at the Fly.io agent server. Settings + web tab visibility come from
# /api/health (Vercel api/health.ts), not from VITE_*.
# ─────────────────────────────────────────────────────────────────────────────

# Agent WebSocket — Fly.io picoclaw bridge
VITE_HOSAKA_AGENT_URL=wss://hosaka-field-terminal-alpha.fly.dev/ws/agent

# Gate the agent channel behind a server-side passphrase.
# The actual passphrase lives ONLY in Fly's HOSAKA_ACCESS_TOKEN secret —
# the client never sees it. Visitors type a candidate word into the shell
# and the server validates it (hmac.compare_digest). This is what lets us
# sell the word-of-mouth access code without leaking it in the JS bundle.
VITE_HOSAKA_GATED=1

# Leave blank — hosted mode uses the Vercel edge proxy at /api/gemini
VITE_HOSAKA_API_BASE=
